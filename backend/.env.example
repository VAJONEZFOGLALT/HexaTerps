# Copy to .env and fill in before running the backend or importer.

# MySQL connection string (Prisma / TiDB Cloud)
# Example: mysql://USER:PASSWORD@HOST:4000/hexaterps?sslaccept=strict
DATABASE_URL=

# Frontend dev origin for CORS (Vite default)
FRONTEND_ORIGIN=http://localhost:5173

# Admin token for protected /api/admin/* endpoints (min 16 chars)
ADMIN_TOKEN=

# Optional: enable importer confirmation without --yes
# IMPORT_HEXATERPS_CONFIRM=1
