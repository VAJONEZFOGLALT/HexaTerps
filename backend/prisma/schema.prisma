// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Strain {
  SATIVA
  INDICA
  HYBRID
}

enum CannabinoidUnit {
  PERCENT
  MG
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryMethod {
  PICKUP
  COURIER
}

model Device {
  id           Int             @id @default(autoincrement())
  name         String          @unique
  productLinks ProductDevice[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  featured  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          Int                   @id @default(autoincrement())
  name        String
  description String?               @db.Text
  flavour     String?
  strain      Strain
  price       Decimal               @db.Decimal(10, 2)
  stock       Int                   @default(0)
  image       String?
  featured    Boolean               @default(false)

  categoryId  Int
  category    Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  cannabinoids ProductCannabinoid[]
  devices      ProductDevice[]

  orderItems   OrderItem[]

  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([categoryId])
  @@index([featured])
}

model Cannabinoid {
  id        Int                   @id @default(autoincrement())
  name      String                @unique
  products  ProductCannabinoid[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model ProductCannabinoid {
  productId     Int
  cannabinoidId Int
  percentage    String  @db.VarChar(40)
  unit          CannabinoidUnit @default(PERCENT)

  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cannabinoid   Cannabinoid @relation(fields: [cannabinoidId], references: [id], onDelete: Restrict)

  @@id([productId, cannabinoidId])
  @@index([cannabinoidId])
}

model ProductDevice {
  id        Int      @id @default(autoincrement())
  productId Int
  deviceId  Int
  price     Decimal  @db.Decimal(10, 2)

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Restrict)

  @@unique([productId, deviceId])
  @@index([deviceId])
}

model Order {
  id             Int            @id @default(autoincrement())
  fullName       String
  contact        String
  deliveryMethod DeliveryMethod
  totalPrice     Decimal        @db.Decimal(10, 2)
  orderStatus    OrderStatus    @default(PENDING)
  note           String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  items          OrderItem[]

  @@index([createdAt])
  @@index([orderStatus])
}

model OrderItem {
  id           Int     @id @default(autoincrement())
  orderId      Int
  productId    Int

  productName  String
  deviceName   String?
  unitPrice    Decimal @db.Decimal(10, 2)
  quantity     Int
  lineTotal    Decimal @db.Decimal(10, 2)

  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}
