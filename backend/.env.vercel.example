# Paste into Vercel → backend project → Settings → Environment Variables
# Production URL: https://hexa-terps-backend.vercel.app
#
# Copy values from your local backend/.env (never commit backend/.env).
# Each row is KEY=value only — do NOT paste "DATABASE_URL=DATABASE_URL=...".

NODE_ENV=production

DATABASE_URL=mysql://USER:PASSWORD@HOST:4000/hexaterps?sslaccept=strict

FRONTEND_ORIGIN=https://hexa-terps.vercel.app

ADMIN_TOKEN=your-long-admin-token-min-16-chars
